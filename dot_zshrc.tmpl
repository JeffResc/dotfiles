# homebrew (Apple Silicon only — /opt/homebrew is the ARM64 prefix)
export HOMEBREW_PREFIX="/opt/homebrew"

# Ensure Homebrew completions are in fpath
if [[ -d "$HOMEBREW_PREFIX/share/zsh/site-functions" ]]; then
    fpath=("$HOMEBREW_PREFIX/share/zsh/site-functions" $fpath)
fi

# Initialize completion system (cached, regenerates daily)
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
  touch ${ZDOTDIR:-$HOME}/.zcompdump
else
  compinit -C
fi

# PATH
export PATH="$HOME/.local/bin:$HOME/go/bin:$HOMEBREW_PREFIX/opt/rustup/bin:$HOME/.cargo/bin:$HOMEBREW_PREFIX/bin:${KREW_ROOT:-$HOME/.krew}/bin:$HOME/.uds/bin:$PATH"

# nvm (lazy loaded)
export NVM_DIR="$HOME/.nvm"
_load_nvm() {
  unset -f nvm node npm npx
  [ -s "$HOMEBREW_PREFIX/opt/nvm/nvm.sh" ] && \. "$HOMEBREW_PREFIX/opt/nvm/nvm.sh"
  [ -s "$HOMEBREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm" ] && \. "$HOMEBREW_PREFIX/opt/nvm/etc/bash_completion.d/nvm"
}
nvm() { _load_nvm && nvm "$@"; }
node() { _load_nvm && node "$@"; }
npm() { _load_nvm && npm "$@"; }
npx() { _load_nvm && npx "$@"; }

# aliases
alias ls='lsd'
alias l='lsd'
alias cat='bat'
alias kctx='kubie ctx'

# kubecolor
alias kubectl='kubecolor'
compdef kubecolor=kubectl

# kube editor
export KUBE_EDITOR="$HOME/.local/bin/kube-edit.sh"

# fzf (cached init, regenerated when the binary is upgraded)
if [[ ! -r ~/.cache/fzf-init.zsh || $HOMEBREW_PREFIX/bin/fzf -nt ~/.cache/fzf-init.zsh ]]; then
  fzf --zsh > ~/.cache/fzf-init.zsh
fi
source ~/.cache/fzf-init.zsh

# azure-select
source "$HOME/.azure-select.sh"

# zoxide (cached init, regenerated when the binary is upgraded)
if [ -z "$DISABLE_ZOXIDE" ]; then
  if [[ ! -r ~/.cache/zoxide-init.zsh || $HOMEBREW_PREFIX/bin/zoxide -nt ~/.cache/zoxide-init.zsh ]]; then
    zoxide init --cmd cd zsh > ~/.cache/zoxide-init.zsh
  fi
  source ~/.cache/zoxide-init.zsh
fi

# menu autocomplete
zstyle ':completion:*' menu select

# kubectl/uds aliases
[ -f ~/.kubectl_aliases ] && source ~/.kubectl_aliases
[ -f ~/.uds_aliases ] && source ~/.uds_aliases

{{- if eq .class "personal" }}
export KUBECONFIG=~/.kube/talos_config
export TALOSCONFIG=~/.talos/talos_config
{{ end }}

# 1Password Account
alias op_account='export OP_ACCOUNT=$(op account ls --format=json | jq -r ".[0].account_uuid")'

# Do Not Track
export DO_NOT_TRACK=1

eval "$(starship init zsh)"
